ninja_required_version = 1.3
cxx = c++

cflags = -pthread -B /home/ubuntu20/anaconda3/envs/pointcloud1/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -O2 -Wall -fPIC -O2 -isystem /home/ubuntu20/anaconda3/envs/pointcloud1/include -I/home/ubuntu20/anaconda3/envs/pointcloud1/include -fPIC -O2 -isystem /home/ubuntu20/anaconda3/envs/pointcloud1/include -fPIC -I/home/ubuntu20/anaconda3/envs/pointcloud1/lib/python3.9/site-packages/torch/include -I/home/ubuntu20/anaconda3/envs/pointcloud1/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/ubuntu20/anaconda3/envs/pointcloud1/lib/python3.9/site-packages/torch/include/TH -I/home/ubuntu20/anaconda3/envs/pointcloud1/lib/python3.9/site-packages/torch/include/THC -I/home/ubuntu20/anaconda3/envs/pointcloud1/include -I/home/ubuntu20/anaconda3/envs/pointcloud1/include/python3.9 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=ext -D_GLIBCXX_USE_CXX11_ABI=0 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=ext -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc





